<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="PCFSamples" constructor="KPIDashboardControl"
		   version="1.0.0" display-name-key="KPIDashboardControl_Display_Key"
		   description-key="KPIDashboardControl_Desc_Key"
		   control-type="standard">

	<!-- Agent/user id to scope performance metrics -->
	<property name="agentId" display-name-key="AgentId_Display_Key"
			  description-key="AgentId_Desc_Key"
			  of-type="SingleLine.Text" usage="input" required="false"
			  default-value="00000000-0000-0000-0001-000000000001" />

	<!-- Show sparkline chart -->
	<property name="showSparklines" display-name-key="ShowSparklines_Display_Key"
			  description-key="ShowSparklines_Desc_Key"
			  of-type="TwoOptions" usage="input" required="false"
			  default-value="true" />

	<!-- Target entity to navigate to on KPI click -->
	<property name="drillDownEntity" display-name-key="DrillDownEntity_Display_Key"
			  description-key="DrillDownEntity_Desc_Key"
			  of-type="SingleLine.Text" usage="input" required="false"
			  default-value="incident" />

	<resources>
	  <code path="index.ts" order="1" />
	  <css path="css/KPIDashboard.css" order="1" />
	</resources>

	<feature-usage>
	  <uses-feature name="WebAPI" required="true" />
	  <uses-feature name="Navigation" required="true" />
	  <uses-feature name="Utility" required="true" />
	</feature-usage>
  </control>
</manifest>
